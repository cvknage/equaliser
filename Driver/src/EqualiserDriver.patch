+#pragma mark Client Tracking
+
+static bool Equaliser_IsAppBundleConnected(void) {
+	bool result = false;
+	pthread_mutex_lock(&gEqualiser_ClientsMutex);
+	
+	if (gEqualiser_Clients != NULL && gEqualiser_AppBundleID != NULL) {
+		CFIndex count = CFArrayGetCount(gEqualiser_Clients);
+		for (CFIndex i = 0; i < count; i++) {
+			CFStringRef clientBundleID = (CFStringRef)CFArrayGetValueAtIndex(gEqualiser_Clients, i);
+			if (CFStringCompare(clientBundleID, gEqualiser_AppBundleID, 0) == kCFCompareEqualTo) {
+				result = true;
+				break;
+			}
+		}
+	}
+	
+	pthread_mutex_unlock(&gEqualiser_ClientsMutex);
+	return result;
+}
+
+static void Equaliser_AddClientBundleID(CFStringRef bundleID) {
+	if (bundleID == NULL) return;
+	
+	pthread_mutex_lock(&gEqualiser_ClientsMutex);
+	
+	// Create array if needed
+	if (gEqualiser_Clients == NULL) {
+		gEqualiser_Clients = CFArrayCreateMutable(NULL, 0, &kCFTypeArrayCallBacks);
+	}
+	
+	// Check if already present
+	CFIndex count = CFArrayGetCount(gEqualiser_Clients);
+	for (CFIndex i = 0; i < count; i++) {
+		if (CFStringCompare(CFArrayGetValueAtIndex(gEqualiser_Clients, i), bundleID, 0) == kCFCompareEqualTo) {
+			pthread_mutex_unlock(&gEqualiser_ClientsMutex);
+			return;  // Already present
+		}
+	}
+	
+	// Add to array - bundleID is retained by the array
+	CFArrayAppendValue(gEqualiser_Clients, bundleID);
+	
+	pthread_mutex_unlock(&gEqualiser_ClientsMutex);
+}
+
+static void Equaliser_RemoveClientBundleID(CFStringRef bundleID) {
+	if (bundleID == NULL || gEqualiser_Clients == NULL) return;
+	
+	pthread_mutex_lock(&gEqualiser_ClientsMutex);
+	
+	CFIndex count = CFArrayGetCount(gEqualiser_Clients);
+	
+	for (CFIndex i = count - 1; i >= 0; i--) {
+		if (CFStringCompare(CFArrayGetValueAtIndex(gEqualiser_Clients, i), bundleID, 0) == kCFCompareEqualTo) {
+			CFArrayRemoveValueAtIndex(gEqualiser_Clients, i);
+			break;
+		}
+	}
+	
+	pthread_mutex_unlock(&gEqualiser_ClientsMutex);
+}
+
+static void Equaliser_UpdateVisibility(AudioServerPlugInHostRef host, AudioObjectID deviceID) {
+	bool shouldBeVisible = Equaliser_IsAppBundleConnected();
+	
+	pthread_mutex_lock(&gPlugIn_StateMutex);
+	bool currentlyVisible = gEqualiser_DeviceShown;
+	
+	if (shouldBeVisible != currentlyVisible) {
+		gEqualiser_DeviceShown = shouldBeVisible;
+		pthread_mutex_unlock(&gPlugIn_StateMutex);
+		
+		// Notify CoreAudio that visibility changed
+		if (host != NULL) {
+			AudioObjectPropertyAddress changedAddr = {
+				kAudioDevicePropertyIsHidden,
+				kAudioObjectPropertyScopeGlobal,
+				kAudioObjectPropertyElementMain
+			};
+			host->PropertiesChanged(host, deviceID, 1, &changedAddr);
+		}
+	} else {
+		pthread_mutex_unlock(&gPlugIn_StateMutex);
+	}
+}
